# ==================== ai-service 环境变量 ====================

# ---- 大模型配置（DeepSeek）----
LLM_PROVIDER=deepseek
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Embedding 模型（DashScope）
EMBEDDING_MODEL=text-embedding-v1
EMBEDDING_DIMENSION=1024
EMBEDDING_API_KEY=your_dashscope_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---- 服务配置 ----
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
DEBUG=true

# ---- 数据库 ----
SQLITE_PATH=./data/ai_hotel.db

# ---- 向量数据库（Milvus，替代 Chroma）----
# Milvus 服务地址（standalone / cluster 均可）
MILVUS_URI=http://localhost:19530
# 鉴权 token（如含账号密码的 API key）；无鉴权留空
MILVUS_TOKEN=
# 集合名（对应原 Chroma collection_name）
MILVUS_COLLECTION=ai_knowledge
# 客户端超时（秒）
MILVUS_TIMEOUT=10

# ---- Java 微服务网关 ----
GATEWAY_URL=http://localhost:8088

# ---- JWT（必须与 Java 端一致）----
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS512

# ---- 日志 ----
LOG_LEVEL=INFO
LOG_FILE=./logs/ai-service.log

# ---- Kafka 日志 ----
KAFKA_BOOTSTRAP_SERVERS=localhost:9091,localhost:9092,localhost:9093
KAFKA_LOG_TOPIC=logs-topic

# ==================== 高并发配置（对等 Java 后端微服务化） ====================

# ---- HTTP 连接池（对等 Druid 连接池）----
HTTP_POOL_MAX_CONNECTIONS=100
HTTP_POOL_MAX_KEEPALIVE=20
HTTP_TIMEOUT=30
HTTP_POOL_TIMEOUT=5

# ---- 网关调用重试（对等 RabbitMQ retry：3 次 + 指数退避）----
HTTP_RETRY_MAX=3
HTTP_RETRY_BACKOFF=0.5

# ---- 熔断（对等 Sentinel 熔断降级）----
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_OPEN_SECONDS=30
CIRCUIT_BREAKER_HALFOPEN_TESTS=1

# ---- Redis（可选；不配置则缓存/锁降级为进程内实现，对等 Java 端 RedisTemplate）----
# 例如：REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# ---- 缓存（对等 @Cacheable / RedisUtil）----
CACHE_DEFAULT_TTL=300
CACHE_RAG_TTL=600

# ---- 限流（对等 Sentinel 网关限流；网关未覆盖 ai-service，此处兜底）----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_QPS=100
RATE_LIMIT_PER_IP_QPS=20
RATE_LIMIT_BURST=50

# ---- 分布式定时锁（对等 SchedulerLock，防止多实例重复执行后台任务）----
ALERT_LOCK_KEY=ai-service:lock:alert-check
ALERT_LOCK_TTL=120

# ---- Embedding 批量（提升吞吐）----
EMBEDDING_BATCH_SIZE=16

# ---- Uvicorn 并发参数（对等于多实例部署 + Tomcat 线程参数）----
WORKERS=1
UVICORN_LIMIT_CONCURRENCY=256
UVICORN_TIMEOUT_KEEP_ALIVE=5
UVICORN_BACKLOG=2048
UVICORN_LIMIT_MAX_REQUESTS=10000
