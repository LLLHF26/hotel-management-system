# ==================== ai-service 环境变量 ====================

# ---- 大模型配置（DeepSeek）----
LLM_PROVIDER=deepseek
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Embedding 模型（DashScope）
EMBEDDING_MODEL=text-embedding-v1
EMBEDDING_DIMENSION=1024
EMBEDDING_API_KEY=your_dashscope_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---- 服务配置 ----
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
DEBUG=true

# ---- 数据库 ----
SQLITE_PATH=./data/ai_hotel.db
CHROMA_PERSIST_PATH=./data/chroma

# ---- Java 微服务网关 ----
GATEWAY_URL=http://localhost:8088

# ---- JWT（必须与 Java 端一致）----
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS512

# ---- 日志 ----
LOG_LEVEL=INFO
LOG_FILE=./logs/ai-service.log

# ---- Kafka 日志 ----
KAFKA_BOOTSTRAP_SERVERS=localhost:9091,localhost:9092,localhost:9093
KAFKA_LOG_TOPIC=logs-topic
